# Required: your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# Optional overrides ---------------------------------------------------------
# Model used for summary + quiz generation (must support Structured Outputs)
OPENAI_MODEL=gpt-4.1-mini

# Port the server listens on
PORT=3000

# Max upload size in megabytes
MAX_FILE_MB=50

# Max characters of extracted text sent to the model (controls cost/length)
MAX_TEXT_CHARS=24000
